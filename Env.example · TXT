# ══════════════════════════════════════════════════════════════
#  إمبراطورية الرياضيات — متغيرات البيئة
#  انسخ هذا الملف إلى .env واملأ القيم الحقيقية
#  تأكد من إضافة .env إلى .gitignore ولا ترفعه أبداً
# ══════════════════════════════════════════════════════════════

# ── JWT ──
# مفتاح سري طويل وعشوائي (استخدم: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHAR_STRING

# ── Supabase ──
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY

# ── حساب الأدمن ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── CORS — النطاقات المسموح بها (افصل بفواصل) ──
# مثال للإنتاج: https://mathempire.yourdomain.com
# مثال للتطوير المحلي: http://localhost:8001,http://127.0.0.1:8001
ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001